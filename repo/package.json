{
  "name": "facility-commerce-operations-api",
  "version": "0.1.0",
  "private": true,
  "description": "Facility Commerce & Operations API Suite",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/app/server.ts",
    "start": "node dist/app/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/run-migrations.ts",
    "db:init": "tsx src/scripts/init-db.ts",
    "benchmark:search": "tsx src/scripts/benchmark-search.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.44.4",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "node-cron": "^4.2.1",
    "pino": "^9.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.1.1",
    "drizzle-kit": "^0.31.1",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
